# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# NOTION_API_KEY: Your Notion Internal Integration Token.
# Get it from https://www.notion.so/my-integrations
NOTION_API_KEY=""

# NOTION_PAGE_ID: The ID of the Notion page where you want to create new pages.
# This can be found in the URL of your Notion page.
NOTION_PAGE_ID=""

# Free-tier cost control flags (recommended when using free Gemini quota)
# true by default in code unless explicitly set to "false"
GEMINI_BUDGET_MODE="true"

# Optional: choose Gemini model order for chat calls.
# Keep lightweight models first for better free-tier survivability.
# GEMINI_MODEL_PRIMARY="gemini-3.1-flash-lite-preview"
# GEMINI_MODEL_FALLBACKS="gemini-3-flash-preview"

# Optional backend reliability tuning (safe defaults are built-in)
# HARD_QUOTA_COOLDOWN_MS="600000"
# REQUEST_WINDOW_MS="60000"
# MAX_REQUESTS_PER_WINDOW="25"
# MAX_MESSAGE_CHARS="6000"
# MAX_HISTORY_MESSAGES="24"
# RESPONSE_CACHE_TTL_MS="90000"

# Optional: when Gemini hard quota is exhausted, return a graceful fallback response
# instead of a hard failure.
# ENABLE_HARD_QUOTA_FALLBACK="true"

# Optional: protect /api/metrics in production (Bearer token or ?token=...)
# METRICS_TOKEN="replace-with-long-random-string"

# Heavy features disabled in budget mode. Enable only if you have quota.
ENABLE_WEB_SEARCH="false"
ENABLE_IMAGE_GENERATION="false"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
